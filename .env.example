# CEREBRO secrets + machine config — copy to `.env` (gitignored) and fill in.
# The real `.env` lives in Bitwarden; pull it onto a new machine rather than re-deriving.
# `scripts/bootstrap.sh` applies it. Shell env always wins over .env.

# ntfy push topic (anyone with it can read your pushes — treat as a secret)
NTFY_TOPIC=

# Obsidian vault path on THIS machine (overrides config/settings.yaml vault_path)
CEREBRO_VAULT=~/d/git/cerebro-vault

# X / twscrape auth — x.com cookies for headless reads (no Firefox needed if set).
# From a logged-in x.com session: DevTools → Application → Cookies → x.com.
X_AUTH_TOKEN=
X_CT0=

# Gmail (gws) OAuth dir as base64 of `tar -C ~/.config -czf - gws`. Optional —
# leave blank and run `gws auth login --readonly -s gmail` on the new machine.
GWS_CONFIG_B64=

# Autoresearch signal-export ingest token (only when export.enabled + export.autoresearch_url
# are set in settings.yaml). The env-var NAME is config (export.token_env); the value is a
# per-tenant Bearer token, keep it here or in Bitwarden, never in the repo.
AUTORESEARCH_TOKEN=

# NOTE: Claude Code auth is NOT here (no API key by design) — run `claude` and log into
# your subscription on the new machine. The private vault repo is cloned separately.
