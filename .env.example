# Copy to .env (gitignored) only if you must. Prefer Keychain + Bitwarden.
#
# Bootstrap token for the Bitwarden Secrets Manager machine account.
# REAL value belongs in macOS Keychain (service: cerebro-bws), fetched by
# scripts/run.sh — NOT here. This file documents the names only.
BWS_ACCESS_TOKEN=

# Optional ntfy topic override (prefer config/settings.yaml).
# NOTE: an ntfy topic is a shared secret — anyone with it can read/publish.
NTFY_TOPIC=
